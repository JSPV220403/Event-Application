model Event_Schedules{
  id String @id @default(uuid())
  event_id String
  image_url String
  date DateTime @db.Date
  time DateTime @db.Time()
  price Decimal @db.Decimal(10,2)
  venue_capacity Int
  map String
  is_active Boolean @default(false)

  event Events[]
  soldTicket Sold_Tickets[]
  address Addresses[]
}