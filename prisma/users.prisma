model Users{
  id String @id @default(uuid())
  image_url String
  name String @db.VarChar(50)
  gender Gender
  phone_number String @db.VarChar(16)
  email String @unique @db.VarChar(255)
  password String
  role Role
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  is_active Boolean @default(false)

  requested_approvals Approvals[] @relation("RequestedBy")
  approved_approvals Approvals[] @relation("ApprovedBy")
  address Addresses[]
  category Categories[]
  soldTicket Sold_Tickets[]
}